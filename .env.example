# Genel (kendi domain'inizi yazın; bu dosyayı kopyalayıp .env.local yapın)
NEXT_PUBLIC_SITE_URL=https://example.com

# Yerel gelistirme (npm run dev bunlari otomatik acar; manuel denemek icin):
# NEXT_PUBLIC_DEV_SIMPLE_ROUTES=1
# SKIP_SANITY_IN_DEV=1

# Sanity (https://www.sanity.io/manage — Project settings'ten Project ID)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# İsteğe bağlı: yazma / migration
# SANITY_API_WRITE_TOKEN=

# Webhook: Sanity → Site — güçlü rastgele dize (ornek metin kullanmayin)
SANITY_REVALIDATE_SECRET=

# İletişim e-postası (boşsa footer’da info@camiikubbekaplama.org kullanılır)
# NEXT_PUBLIC_CONTACT_EMAIL=info@camiikubbekaplama.org

# Anasayfa yüzen Instagram butonu (tam profil URL’si)
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/...

# Mobil footer: tam adres satırı (yoksa kısa varsayılan gösterilir)
# NEXT_PUBLIC_FOOTER_ADDRESS=Törekent Mah. 307.Sk No:14 Sincan / Ankara

# Footer sosyal (isteğe bağlı — tanımlı olanlar gösterilir)
# NEXT_PUBLIC_FACEBOOK_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
# NEXT_PUBLIC_YOUTUBE_URL=

# Gtag (Sanity’de adScripts yoksa yedek)
# NEXT_PUBLIC_GOOGLE_ADS_ID=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads dönüşüm etiketleri (format: AW-123456789/AbC-dEfGh)
# NEXT_PUBLIC_GADS_CONVERSION_TEKLIF=
# NEXT_PUBLIC_GADS_CONVERSION_WHATSAPP=
# NEXT_PUBLIC_GADS_CONVERSION_PHONE=
# NEXT_PUBLIC_GADS_CONVERSION_THANKYOU=
# İletişim formu (generate_lead) — tanımlı değilse WhatsApp dönüşümüne düşer
# NEXT_PUBLIC_GADS_CONVERSION_LEAD=
# AdresGezgini / ikinci hesap için aynı olaylara ek send_to (isteğe bağlı)
# NEXT_PUBLIC_ADRESGEZGINI_CONVERSION_WHATSAPP=
# NEXT_PUBLIC_ADRESGEZGINI_CONVERSION_PHONE=
# NEXT_PUBLIC_ADRESGEZGINI_CONVERSION_THANKYOU=
# NEXT_PUBLIC_ADRESGEZGINI_CONVERSION_LEAD=
