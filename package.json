{
  "name": "kubbe-kurumsal-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:full": "next dev -p 3000 -H 127.0.0.1",
    "dev:simple": "node scripts/dev.mjs",
    "dev:local": "next dev -p 3000 -H 127.0.0.1",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path '.next') { Remove-Item -Recurse -Force '.next' }; next dev\"",
    "messages:build": "node scripts/build-en-ar-messages.mjs",
    "messages:check": "node scripts/build-en-ar-messages.mjs --check-only",
    "prebuild": "npm run messages:build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "optimize:images": "node scripts/optimize-public-media.mjs",
    "build:prod": "npm run optimize:images && npm run build"
  },
  "dependencies": {
    "@sanity/image-url": "^1.1.0",
    "@sanity/vision": "^3.68.0",
    "@types/leaflet": "^1.9.21",
    "framer-motion": "^11.18.2",
    "i18next": "^25.10.5",
    "leaflet": "^1.9.4",
    "next": "^14.2.18",
    "next-sanity": "^9.8.0",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.2",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0",
    "sanity": "^3.68.0",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
